# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_123
POSTGRES_DB=inventoryflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy Database URL (for FastAPI container to connect to PostgreSQL container)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password_123@postgres:5432/inventoryflow

# Application Environment
ENVIRONMENT=development
API_V1_STR=/api
PROJECT_NAME=InventoryFlow
